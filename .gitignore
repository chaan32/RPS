# 비번같은 거 공유 파일들 깃에 안 올라갈 파일 들

# 보안/환경변수 
.env

# 가상환경 폴더
.venv/
venv/
env/

# 파이썬 캐시 파일 (의미 없는 찌꺼기 파일들)
__pycache__/
*.py[cod]
*$py.class

# OS 시스템 파일 (맥북 찌꺼기 등)
.DS_Store
Thumbs.db

# 에디터 설정 (개인 VS Code 설정 등)
.vscode/
.idea/

# 클로드 설정
.claude

# ── 모델 가중치 / 학습 산출물
# Ultralytics 사전학습 모델 (자동 다운로드되므로 커밋 불필요)
**/yolo11n*.pt

# YAMNet 학습 임베딩 캐시 (운영에서 미사용)
model/yamnet/anomaly_embeddings.npy

# YAMNet 학습 데이터셋은 DVC 가 관리 (model/yamnet/dataset.dvc 참조)
# DVC 가 model/yamnet/dataset/ 안의 .gitignore 를 자동 생성하므로 여기선 제외

# ── 운영 산출물
# 사고 스냅샷 폴백 디렉토리 (USB 미마운트 시 사용)
snapshots/

# ── 문서 / 다이어그램
# 내부 작업용 — 깃에 올리지 않음
docs/

# 성능 측정 로그 (Phase 1+ 누적)
metrics/

# 유니티 시뮬레이션
simulation/

# 프론트엔드 빌드 산출물 제거
frontend/dist/