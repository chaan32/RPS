digraph SafetyMonitoring {
  // ── 전체 설정 ─────────────────────────────────────────────────────
  rankdir=TB;
  graph [
    fontname="AppleSDGothicNeo",
    fontsize=14,
    label="산업 안전 모니터링 시스템 — 전체 플로우",
    labelloc="t",
    nodesep=0.4,
    ranksep=0.6,
    splines=spline,
    bgcolor="white"
  ];
  node  [fontname="AppleSDGothicNeo", fontsize=10, shape=box, style="rounded,filled", margin="0.15,0.08"];
  edge  [fontname="AppleSDGothicNeo", fontsize=9, color="#444444"];

  // ── 입력 레이어 ───────────────────────────────────────────────────
  subgraph cluster_input {
    label="① 입력 (Input Layer)";
    style="rounded,filled"; fillcolor="#FFF4E0"; fontsize=12;
    cam1   [label="RTSP 카메라 #1\n(작업장 정면)",  fillcolor="#FFD580"];
    cam2   [label="RTSP 카메라 #2\n(작업장 측면)",  fillcolor="#FFD580"];
    esp32  [label="ESP32\n(WebSocket 오디오)",       fillcolor="#FFD580"];
  }

  // ── 시각 처리 파이프라인 ──────────────────────────────────────────
  subgraph cluster_vision {
    label="② 시각 처리 (Vision Pipeline)";
    style="rounded,filled"; fillcolor="#E0F0FF"; fontsize=12;

    yolo_pose   [label="YOLO11n-pose\n(작업자 keypoint)",     fillcolor="#9EC9F2"];
    yolo_custom [label="YOLO custom\n(forklift / box_1 / box_2)", fillcolor="#9EC9F2"];
    aruco       [label="ArUco 검출\n(corners 22/24/27/38\n+ workers 5/10/15)", fillcolor="#9EC9F2"];
    homo        [label="Homography\npixel → world (m)",       fillcolor="#9EC9F2"];
    pipeline    [label="DetectionPipeline.extract()\n(input/media/pipeline/engine.py)", fillcolor="#5DA5DA", fontcolor="white"];
    crosscam    [label="Cross-Camera\n작업자 ID 통합\n(world 좌표 1.5m 이내)", fillcolor="#9EC9F2"];
  }

  // ── 청각 처리 ─────────────────────────────────────────────────────
  subgraph cluster_audio {
    label="③ 청각 처리 (Audio)";
    style="rounded,filled"; fillcolor="#F5E6FF"; fontsize=12;

    yamnet     [label="YAMNet 임베딩",                  fillcolor="#C4A0E8"];
    centroid   [label="Centroid Cosine 유사도\n(threshold 0.68)",  fillcolor="#C4A0E8"];
    audio_score[label="이상음 점수 (0~1)",              fillcolor="#A77DD0", fontcolor="white"];
  }

  // ── 융합 모델 ─────────────────────────────────────────────────────
  subgraph cluster_fusion {
    label="④ 융합 모델 (Fusion ~11K params)";
    style="rounded,filled"; fillcolor="#E8F5E9"; fontsize=12;

    kine      [label="WorkerKinematics\n(속도 / 방향)",          fillcolor="#A5D6A7"];
    graph_in  [label="Graph Input\n(node feat + edge)",          fillcolor="#A5D6A7"];
    gcn       [label="GCN Branch",                                fillcolor="#A5D6A7"];
    temporal  [label="Temporal Branch\n(T_WIN 슬라이딩)",         fillcolor="#A5D6A7"];
    threat    [label="Threat Branch\n(거리 / 접근속도)",          fillcolor="#A5D6A7"];
    fusion    [label="Pairwise Interaction\nFusion Model",        fillcolor="#4CAF50", fontcolor="white"];
    risk      [label="Risk Output\n(per pair × 3 class)\n· forklift–worker\n· dropzone–worker",   fillcolor="#388E3C", fontcolor="white"];
  }

  // ── 규칙 보정 ─────────────────────────────────────────────────────
  subgraph cluster_rules {
    label="⑤ 규칙 보정";
    style="rounded,filled"; fillcolor="#FFEBEE"; fontsize=12;

    rule_static  [label="정지 forklift 무시\n(speed < 0.10 m/s)",     fillcolor="#EF9A9A"];
    rule_drop    [label="드롭존 0.5m 접근\n→ 즉시 위험",                fillcolor="#EF9A9A"];
    rule_front   [label="전방(front) 작업자\n→ 알림 차단",              fillcolor="#EF9A9A"];
  }

  // ── 출력 레이어 ───────────────────────────────────────────────────
  subgraph cluster_output {
    label="⑥ 출력 (Output Layer)";
    style="rounded,filled"; fillcolor="#FFF9C4"; fontsize=12;

    mqtt    [label="MQTT Publisher\nforklift/4/vibration\n{back, left, right}", fillcolor="#FFE082"];
    db      [label="DB Logger\nPostgreSQL\n(incident 테이블)",                   fillcolor="#FFE082"];
    snap    [label="Snapshot 저장\nUSB 또는 ./snapshots",                        fillcolor="#FFE082"];
    wear    [label="ESP32 진동 wearable",  fillcolor="#FFB300", shape=ellipse];
  }

  // ── 상위 서버 (FastAPI) ────────────────────────────────────────────
  subgraph cluster_server {
    label="⑦ FastAPI 서버 (server/main.py)";
    style="rounded,filled"; fillcolor="#ECEFF1"; fontsize=12;

    fastapi [label="FastAPI lifespan\n(자동 subprocess spawn)",  fillcolor="#90A4AE", fontcolor="white"];
    api     [label="REST /api/*\nWebSocket /ws/audio",            fillcolor="#B0BEC5"];
    front   [label="React Frontend\n(Nginx 정적 + /api 프록시)",  fillcolor="#B0BEC5"];
    user    [label="운영자 브라우저",  fillcolor="#607D8B", fontcolor="white", shape=ellipse];
  }

  // ── 데이터 흐름 (간선) ──────────────────────────────────────────────
  cam1 -> yolo_pose;
  cam1 -> yolo_custom;
  cam1 -> aruco;
  cam2 -> yolo_pose;
  cam2 -> yolo_custom;
  cam2 -> aruco;

  yolo_pose   -> pipeline;
  yolo_custom -> pipeline;
  aruco       -> homo -> pipeline;
  pipeline    -> crosscam;

  esp32 -> api          [label="WS /ws/audio"];
  api   -> yamnet       [label="PCM 프레임"];
  yamnet -> centroid -> audio_score;

  crosscam   -> kine;
  kine       -> graph_in;
  graph_in   -> gcn;
  graph_in   -> temporal;
  graph_in   -> threat;
  audio_score -> threat   [label="audio feat"];
  gcn      -> fusion;
  temporal -> fusion;
  threat   -> fusion;
  fusion -> risk;

  risk -> rule_static;
  rule_static -> rule_drop -> rule_front;

  rule_front -> mqtt   [label="위험 시"];
  rule_front -> db     [label="모든 결정"];
  rule_front -> snap   [label="위험 시"];
  mqtt -> wear         [style=dashed, label="LAN MQTT"];

  // ── 서버 통합 ──────────────────────────────────────────────────────
  fastapi -> pipeline   [style=dashed, label="subprocess\nspawn"];
  fastapi -> api;
  api -> db             [style=dashed, label="조회"];
  api -> snap           [style=dashed, label="조회"];
  user -> front -> api  [label="HTTP / WS"];
}
