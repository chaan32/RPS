digraph MediaFlow {
  rankdir=TB;
  graph [
    fontname="AppleSDGothicNeo",
    fontsize=14,
    label="input/media — 함수 단위 실행 흐름 (진입점 → 출력)",
    labelloc="t",
    nodesep=0.35,
    ranksep=0.55,
    splines=spline,
    bgcolor="white",
    compound=true
  ];
  node [fontname="AppleSDGothicNeo Menlo", fontsize=10, shape=box, style="rounded,filled", margin="0.15,0.08"];
  edge [fontname="AppleSDGothicNeo", fontsize=9, color="#444444"];

  // ─────────────────────────────────────────────────────────────────────
  // ① ENTRY
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_entry {
    label="① 진입점 (Entry)";
    style="rounded,filled"; fillcolor="#FFF4E0"; fontsize=12;

    cli       [label="$ python -m input.media.pipeline.runner --live\n(또는 server/main.py 의 subprocess 가 fork)", shape=note, fillcolor="#FFE0B2"];
    main_fn   [label="runner.py :: main()\n(argparse)\nL167", fillcolor="#FFB74D", fontcolor="white"];
    decision  [label="모드 분기?", shape=diamond, fillcolor="#FFCC80"];
  }

  cli -> main_fn -> decision;

  // ─────────────────────────────────────────────────────────────────────
  // ② SETUP (캘리브레이션 + 카메라 + 모델)
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_setup {
    label="② 셋업 단계 (run_live 의 Phase 1~3)";
    style="rounded,filled"; fillcolor="#E0F0FF"; fontsize=12;

    run_live  [label="runner.py :: run_live()\nL74", fillcolor="#5DA5DA", fontcolor="white"];
    run_image [label="runner.py :: run_image()\nL50  (단일 사진 모드)", fillcolor="#90CAF9"];

    // -- 캘리브레이션 보장 --
    subgraph cluster_calib {
      label="Phase 1·2 — 캘리브레이션 자동 보장";
      style="rounded,dashed"; fillcolor="#F0F8FF"; fontsize=10;

      ensure       [label="calibration_runtime.py ::\nensure_calibration(cam_id, rtsp)\nL72", fillcolor="#9EC9F2"];
      cap_snap     [label="calibration_runtime.py ::\ncapture_rtsp_snapshot()\nL21", fillcolor="#9EC9F2"];
      run_calib    [label="calibrate_homography.py ::\nrun_calibration(cam_id, image_path)\nL96", fillcolor="#9EC9F2"];
      detect_aruco [label="calibrate_homography.py ::\ndetect_aruco_centers()\nL44", fillcolor="#BBDEFB"];
      load_markers [label="calibrate_homography.py ::\nload_world_markers()\nL32  (ArUco ID → 실측 (x,y))", fillcolor="#BBDEFB"];
      compute_H    [label="calibrate_homography.py ::\ncompute_homography()\nL61  (cv2.findHomography)", fillcolor="#BBDEFB"];
    }

    // -- 카메라 스트림 --
    subgraph cluster_cam {
      label="Phase 3 — RTSP 스트림 시작";
      style="rounded,dashed"; fillcolor="#F0F8FF"; fontsize=10;

      vs_init   [label="camera.py ::\nVideoStream(rtsp_url).__init__()\nL34", fillcolor="#9EC9F2"];
      vs_start  [label="VideoStream.start()\nL52  (첫 프레임 대기 + 백그라운드 스레드)", fillcolor="#9EC9F2"];
      vs_update [label="VideoStream._update()\nL65  (스레드 안에서 무한 read)", fillcolor="#BBDEFB", shape=cds];
    }

    // -- 모델 로드 --
    subgraph cluster_model {
      label="Phase 4 직전 — 모델 로드";
      style="rounded,dashed"; fillcolor="#F0F8FF"; fontsize=10;

      build_pl    [label="runner.py :: build_default_pipeline()\nL40  (.env 의 BEST_MODEL_PATH 읽음)", fillcolor="#9EC9F2"];
      pl_init     [label="engine.py :: DetectionPipeline.__init__()\nL49", fillcolor="#5DA5DA", fontcolor="white"];
      load_yolo   [label="YOLO('yolo11n-pose.pt')\n+ YOLO(best_final.pt)", fillcolor="#BBDEFB"];
      build_aruco [label="_build_aruco_detector()\nL93  (DICT_5X5_50)", fillcolor="#BBDEFB"];
    }
  }

  // ─────────────────────────────────────────────────────────────────────
  // ③ MAIN LOOP — extract() 한 프레임 처리
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_loop {
    label="③ 메인 루프 (Phase 4) — 매 프레임마다 반복";
    style="rounded,filled"; fillcolor="#E8F5E9"; fontsize=12;

    loop_top   [label="while True:\n  ret1, f1 = cam1.read()\n  ret2, f2 = cam2.read()", shape=note, fillcolor="#C8E6C9"];

    // -- extract() 메서드 -- (cam1, cam2 두 번 호출)
    subgraph cluster_extract {
      label="DetectionPipeline.extract(frame, cam_id)  L105  ── cam1, cam2 각각 호출";
      style="rounded,dashed"; fillcolor="#F1F8E9"; fontsize=10;

      step_a    [label="(a) self.pose_model.track(frame)\nL111  → 사람 bbox + 17 keypoint + track_id",        fillcolor="#A5D6A7"];
      step_a1   [label="(a-1) self.aruco_detector.detectMarkers(frame)\nL116  → 마커 ID + 4코너 픽셀",         fillcolor="#A5D6A7"];

      step_1    [label="(1) _collect_worker_entries()\nL160  ── 사람마다 처리",                                fillcolor="#A5D6A7"];
      pick_foot [label="_pick_foot_point()\nL201  (양발목 평균 → 폴백 bbox 하단)",                              fillcolor="#C5E1A5"];
      px2w_a    [label="world_mapper.py :: pixel_to_world(fx, fy, cam_id)\nL41",                                fillcolor="#C5E1A5"];
      load_H    [label="world_mapper.py :: load_homography(cam_id)\nL21  (JSON 1회 캐시)",                       fillcolor="#DCEDC8"];

      step_15   [label="(1.5) cam_track_to_worker[tid] 조회\nL140  (시간축 ID 유지)",                            fillcolor="#A5D6A7"];

      step_2    [label="(2) _match_aruco_to_bbox()\nL231  (greedy 1:1, dist ≤ max(bbox W, H))",                 fillcolor="#A5D6A7"];

      step_b    [label="(b) _extract_custom_objects()\nL272  → forklift / box_1 / box_2",                       fillcolor="#A5D6A7"];
      px2w_b    [label="pixel_to_world() 재호출\n(box_1/2 는 bbox 하단 중심 사용 ← 공중 인양물 보정)",            fillcolor="#C5E1A5"];

      ret_dets  [label="return detections : list[dict]\n[{type, worker_id, bbox_px, foot_px, world{x,y}}, ...]", shape=note, fillcolor="#FFFDE7"];
    }

    // -- 두 카메라 합치기 --
    cross_prop [label="DetectionPipeline.cross_camera_propagate({cam1, cam2})\nL307  (한쪽이 식별한 worker_id → 반대쪽 미식별 person 에 전파, 1.5m 이내)", fillcolor="#66BB6A", fontcolor="white"];
  }

  // ─────────────────────────────────────────────────────────────────────
  // ④ OUTPUT
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_out {
    label="④ 출력 (Output)";
    style="rounded,filled"; fillcolor="#FFF9C4"; fontsize=12;

    json_dump [label="print(json.dumps(payload))\nrunner.py:151\n→ stdout (parent process pipe)",            fillcolor="#FFE082", shape=note];
    draw_fn   [label="visualization.py :: draw_annotated(frame, dets)\nL25",                                  fillcolor="#FFE082"];
    cv_show   [label="cv2.imshow('cam1' / 'cam2')\nrunner.py:155-157  (--no-show 면 skip)",                   fillcolor="#FFD54F"];
    cv_save   [label="cv2.imwrite(cam1_detected.jpg)\nrunner.py:68  (이미지 모드만)",                          fillcolor="#FFD54F"];

    parent    [label="server/main.py 또는\nmodel/fusion/runtime/realtime_camera.py\n(JSON 줄 단위 파싱)",   fillcolor="#FFB300", shape=parallelogram];
  }

  // ─────────────────────────────────────────────────────────────────────
  // ⑤ 영속 자원 (사이드 인풋)
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_files {
    label="⑤ 디스크 자원 (사이드 인풋)";
    style="rounded,filled"; fillcolor="#ECEFF1"; fontsize=12;

    f_homog [label="calibration/{cam}_homography.json", shape=cylinder, fillcolor="#CFD8DC"];
    f_snap  [label="calibration/test_{cam}.jpg",        shape=cylinder, fillcolor="#CFD8DC"];
    f_yolo  [label="yolo11n-pose.pt\nmodel/yolo/best_final.pt", shape=cylinder, fillcolor="#CFD8DC"];
    f_const [label="pipeline/constants.py\nWORKER_ARUCO_MAP {5:W01, 10:W02, 15:W03}\nWORLD_MATCH_RADIUS_M=1.0\nKPT_CONF_THRESHOLD=0.3", shape=cylinder, fillcolor="#CFD8DC"];
    f_env   [label=".env\nCAMERA_RTSP_URL_1/2\nBEST_MODEL_PATH",                          shape=cylinder, fillcolor="#CFD8DC"];
  }

  // ─────────────────────────────────────────────────────────────────────
  // 간선
  // ─────────────────────────────────────────────────────────────────────
  decision -> run_image  [label="--cam --image"];
  decision -> run_live   [label="--live"];

  run_live -> ensure       [label="cam1, cam2 각각"];
  ensure   -> cap_snap     [label="JSON 없고 jpg 도 없으면"];
  cap_snap -> f_snap       [style=dashed, label="cv2.imwrite"];
  ensure   -> run_calib    [label="JSON 없을 때"];
  run_calib -> detect_aruco;
  run_calib -> load_markers;
  detect_aruco -> compute_H;
  load_markers -> compute_H;
  compute_H -> f_homog     [style=dashed, label="JSON 저장"];

  run_live -> vs_init      [label="rtsp_1, rtsp_2"];
  f_env    -> run_live     [style=dashed];
  vs_init  -> vs_start;
  vs_start -> vs_update    [style=dashed, label="thread"];

  run_live -> build_pl;
  f_env    -> build_pl     [style=dashed];
  build_pl -> pl_init;
  pl_init  -> load_yolo;
  pl_init  -> build_aruco;
  f_yolo   -> load_yolo    [style=dashed];

  // ── 메인 루프 진입 ──
  build_pl  -> loop_top    [lhead=cluster_loop];
  vs_update -> loop_top    [style=dashed, label="self.frame 갱신"];
  loop_top  -> step_a      [label="extract(f1, 'cam1')\nextract(f2, 'cam2')"];

  // extract 내부
  step_a    -> step_a1;
  step_a1   -> step_1;
  step_1    -> pick_foot;
  pick_foot -> px2w_a;
  px2w_a    -> load_H;
  load_H    -> f_homog     [style=dashed, label="첫 호출만 read"];

  step_1    -> step_15;
  step_15   -> step_2;
  f_const   -> step_2      [style=dashed, label="WORKER_ARUCO_MAP"];

  step_2    -> step_b;
  step_b    -> px2w_b;
  px2w_b    -> load_H      [style=dashed];

  step_b    -> ret_dets;
  ret_dets  -> cross_prop  [label="cam1, cam2 결과 합쳐 호출"];

  // 출력
  cross_prop -> json_dump;
  cross_prop -> draw_fn;
  draw_fn    -> cv_show;
  json_dump  -> parent     [label="line-by-line"];

  // image 모드 출력
  run_image -> cv_save     [style=dashed, label="annotated jpg"];
  run_image -> json_dump   [style=dashed];

  // 루프백
  cv_show   -> loop_top    [label="ESC 아니면 다음 프레임", style=dotted, constraint=false];
}
