# 산업 안전 모니터링 시스템 — 환경변수 템플릿.
# 이 파일을 `.env` 로 복사한 뒤 자신의 환경에 맞게 채워 사용.
#
#   cp .env.example .env
#   conda activate venv

# ── 서버 ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=1122
FUSION_SERVER_URL=http://127.0.0.1:1122

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=haechan
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pobiga_db
DATABASE_URL=postgresql+asyncpg://haechan:change_me@127.0.0.1:5432/pobiga_db

# ── MQTT 브로커 ──────────────────────────────────────────────────────
MQTT_BROKER=127.0.0.1

# 진동 토픽 (펌웨어가 구독)
MQTT_FORKLIFT_01=forklift/01/vibration
MQTT_FORKLIFT_02=forklift/02/vibration
MQTT_CRANE_01=crane/01/vibration
MQTT_CRANE_02=crane/02/vibration
MQTT_CRANE_03=crane/03/vibration

# ── 카메라 RTSP ──────────────────────────────────────────────────────
# Unity 녹화 프레임을 MediaMTX로 publish하는 기본 개발 환경.
# 실제 CCTV를 붙일 때만 rtsp://USER:PASS@IP:PORT/... 형태로 바꾼다.
CAMERA_RTSP_URL_1=rtsp://localhost:8554/cam1
CAMERA_RTSP_URL_2=rtsp://localhost:8554/cam2

# ── LLM 백엔드 ───────────────────────────────────────────────────────
# "gemini" 또는 "local"
LLM_BACKEND=local

# Gemini (LLM_BACKEND=gemini 시 필요)
GEMINI_API_KEY=

# Ollama (LLM_BACKEND=local 시)
OLLAMA_HOST=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen3:8b

# ── 모델 가중치 경로 ──────────────────────────────────────────────────
BEST_MODEL_PATH=model/yolo/best_forklift_box_colab.pt
POSE_MODEL_PATH=model/yolo/yolo11s-pose.pt
POSE_IMGSZ=640
CUSTOM_IMGSZ=512
POSE_EVERY_N_FRAMES=2
WORKER_WORLD_BOUNDS=none
FORKLIFT_HAZARD_FORWARD_OFFSET_M=1.0
FORKLIFT_HAZARD_MIN_DISPLACEMENT_M=0.25
DROPZONE_ALERT_RADIUS_M=0.5
EXTRACT_MODE=model_parallel
TARGET_RATE=0
RISK_ENGINE=v2
FUSION_V2_CHECKPOINT=model/fusion_v2/checkpoints_geometry_future/best.pt
FUSION_V2_WINDOW_SIZE=24

# ── 사고 스냅샷 저장 ─────────────────────────────────────────────────
# USB 마운트 경로 (호스트). 미마운트 시 LOCAL_SNAPSHOT_PATH 자동 폴백.
USB_STORE_PATH=/Volumes/THXMRHD
LOCAL_SNAPSHOT_PATH=./snapshots

# ── Redis background jobs ─────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_JOB_QUEUE_KEY=rps:jobs:queue
REDIS_JOB_KEY_PREFIX=rps:jobs:
