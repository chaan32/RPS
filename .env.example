# 산업 안전 모니터링 시스템 — 환경변수 템플릿.
# 이 파일을 `.env` 로 복사한 뒤 자신의 환경에 맞게 채워 사용.
#
#   cp .env.example .env
#   docker compose up -d

# ── 서버 ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=1122

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=haechan
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pobiga_db
DATABASE_URL=postgresql+asyncpg://haechan:change_me@127.0.0.1:5432/pobiga_db

# ── MQTT 브로커 ──────────────────────────────────────────────────────
MQTT_BROKER=127.0.0.1

# 진동 토픽 (펌웨어가 구독)
MQTT_FORKLIFT_01=forklift/01/vibration
MQTT_FORKLIFT_02=forklift/02/vibration
MQTT_CRANE_01=crane/01/vibration
MQTT_CRANE_02=crane/02/vibration
MQTT_CRANE_03=crane/03/vibration

# ── 카메라 RTSP ──────────────────────────────────────────────────────
CAMERA_RTSP_URL_1=rtsp://USER:PASS@192.168.0.10:554/stream2
CAMERA_RTSP_URL_2=rtsp://USER:PASS@192.168.0.11:554/stream2

# ── LLM 백엔드 ───────────────────────────────────────────────────────
# "gemini" 또는 "local"
LLM_BACKEND=local

# Gemini (LLM_BACKEND=gemini 시 필요)
GEMINI_API_KEY=

# Ollama (LLM_BACKEND=local 시)
OLLAMA_HOST=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen3:8b

# ── 모델 가중치 경로 ──────────────────────────────────────────────────
BEST_MODEL_PATH=model/yolo/best_final.pt

# ── 사고 스냅샷 저장 ─────────────────────────────────────────────────
# USB 마운트 경로 (호스트). 미마운트 시 LOCAL_SNAPSHOT_PATH 자동 폴백.
USB_STORE_PATH=/Volumes/THXMRHD
LOCAL_SNAPSHOT_PATH=./snapshots
